---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Outfit:wght@700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --cream: #fef3c7;
    --white: #ffffff;
    --gray-50: #f9fafb;
    --gray-100: #f3f4f6;
    --gray-200: #e5e7eb;
    --gray-300: #d1d5db;
    --gray-400: #bcc0c5;
    --gray-600: #4b5563;
    --gray-700: #374151;
    --gray-800: #1f2937;
    --gray-900: #111827;
    --red-dark: #8b0000;
    --red-light: #c06c73;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    background: linear-gradient(
      to bottom,
      #d9969e 0%,
      #8b0000 65%,
      #1a0a0a 90%,
      #0a0a0a 100%
    ); /*the gradient has to be inverted for some reason*/
    background-attachment: fixed;
    background-repeat: no-repeat;
  }

  body {
    font-family: "Inter", sans-serif;
    line-height: 1.6;
    color: var(--white);
    background: transparent;
  }

  .font-display {
    font-family: "Outfit", serif;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section-padding {
    padding: 5rem 0;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    font-size: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #4a0404 0%, #c90c0c 100%);
    color: var(--white);
    box-shadow: 0 4px 25px 2px rgba(255, 0, 0, 0.6);
    transition: all 0.3s ease; 
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(255, 0, 0, 0.7);
  }
  
  .btn-secondary {
    background: transparent;
    color: var(--primary-blue);
    border: 2px solid var(--primary-blue);
  }

  .btn-secondary:hover {
    background: var(--primary-blue);
    color: var(--white);
    transform: translateY(-2px);
  }

  .text-gradient {
    background: linear-gradient(
      135deg,
      var(--primary-blue) 0%,
      var(--royal-blue) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .gold-gradient {
    background: linear-gradient(135deg, var(--gold) 0%, var(--light-gold) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .card {
    /* Semi-transparent background */
    background: rgba(255, 255, 255, 0.1);

    /* The "Glass" magic: blurs whatever is behind the element */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px); /* Support for Safari */

    /* Modern rounded corners */
    border-radius: 1rem;
    padding: 2rem;

    /* A very thin, light border helps define the edges on dark/busy backgrounds */
    border: 1px solid rgba(255, 255, 255, 0.2);

    /* Soft shadow to give it depth without looking heavy */
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1);

    transition: all 0.3s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
  }

  @media (max-width: 768px) {
    .container {
      padding: 0 1rem;
    }

    .section-padding {
      padding: 3rem 0;
    }
  }
</style>
