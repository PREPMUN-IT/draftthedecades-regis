---
import { Image } from 'astro:assets';
import birdImage from '/public/IMG_0449.PNG';
---

<section id="registration" class="registration section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title font-display text-gradient">Registration</h2>
      <p class="section-subtitle">
        Ready to shape Singapore's future? Here's how to join Drafting the Decades.
      </p>
    </div>

    <div class="registration-content">
      <div class="registration-info">
        <div class="info-card card">
          <div class="card-header">
            <div class="card-icon">📝</div>
            <h3 class="card-title font-display">How to Register</h3>
          </div>
          
          <div class="registration-steps">
            <div class="step">
              <div class="step-number">1</div>
              <div class="step-content">
                <h4 class="step-title">Form Your Team</h4>
                <p class="step-description">
                  Gather 3-5 members from any Singapore educational institution aged between 14 to 25 years old (inclusive). Solo participants welcome - we'll help you find teammates!
                </p>
              </div>
            </div>
            
            <div class="step">
              <div class="step-number">2</div>
              <div class="step-content">
                <h4 class="step-title">Complete Registration</h4>
                <p class="step-description">
                  Only one team member (Point of Contact) needs to complete the registration form on behalf of the group / pair. Solo participants are required to sign up independently.
                </p>
              </div>
            </div>
            
            <div class="step">
              <div class="step-number">3</div>
              <div class="step-content">
                <h4 class="step-title">Pay Deposit</h4>
                <p class="step-description">
                  A refundable deposit of SGD $10 per participant is required. A full refund will be processed within three working days after attendance at the event.
                </p>
              </div>
            </div>
          </div>
        </div>

        <div class="deadline-card card">
          <div class="deadline-content">
            <div class="deadline-icon">⏰</div>
            <div class="deadline-text">
              <h3 class="deadline-title font-display">Registration Deadline</h3>
              <p class="deadline-date">2 August 2025 (Sat), 11:59 PM</p>
              <p class="deadline-note">
                Registration confirmation and event details will be sent to your / point of contact's registered email after sign-up. Check your spam folder just in case!
              </p>
            </div>
          </div>
        </div>
      </div>

      <div class="registration-action">
        <div class="action-card">
          <div class="action-content">
            <h3 class="action-title font-display">Ready to Begin?</h3>
            <p class="action-description">
              Join us in exploring Singapore's past to build its future. 
              Register now and become part of this unique SG60 experience.
            </p>
            
            <div class="action-buttons">
              <a href="https://forms.gle/ARhbN4R2oymJavrM8" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-large" id="register">
                Register Your Team
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
              <p class="contact-info">
                Questions? Contact us at <strong>events@prepmun.sg</strong>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .registration {
    background: linear-gradient(135deg, var(--gray-50) 0%, var(--white) 100%);
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.25rem;
    color: var(--gray-600);
    max-width: 600px;
    margin: 0 auto;
  }

  .registration-content {
    display: grid;
    gap: 3rem;
  }

  .registration-info {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 2rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .card-icon {
    font-size: 2rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--gold) 0%, var(--light-gold) 100%);
    border-radius: 0.75rem;
  }

  .card-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--gray-800);
  }

  .registration-steps {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }

  .step-number {
    width: 2.5rem;
    height: 2.5rem;
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--royal-blue) 100%);
    color: var(--white);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    flex-shrink: 0;
  }

  .step-title {
    font-weight: 600;
    color: var(--gray-800);
    margin-bottom: 0.5rem;
  }

  .step-description {
    color: var(--gray-700);
    line-height: 1.6;
  }

  .deadline-card {
    background: linear-gradient(135deg, var(--cream) 0%, rgba(251, 191, 36, 0.1) 100%);
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  .deadline-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .deadline-icon {
    font-size: 3rem;
  }

  .deadline-title {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--gray-800);
    margin-bottom: 0.5rem;
  }

  .deadline-date {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .deadline-note {
    font-size: 0.9rem;
    color: var(--gray-600);
    line-height: 1.5;
  }

  .action-card {
    background: var(--white);
    border-radius: 1.5rem;
    padding: 3rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
    border: 1px solid var(--gray-100);
    text-align: center;
  }

  .action-title {
    font-size: 2rem;
    font-weight: 600;
    color: var(--gray-800);
    margin-bottom: 1rem;
  }

  .action-description {
    font-size: 1.125rem;
    color: var(--gray-700);
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .action-buttons {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1.125rem;
    gap: 0.5rem;
    justify-content: center;
  }

  .contact-info {
    font-size: 0.9rem;
    color: var(--gray-600);
    text-align: center;
  }


  .free-bird {
    position: absolute;
    top: 20%;
    right: 5%;
    width: 200px;
    height: auto;
    z-index: 10;
    border-radius: 1rem;
    box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
    transition: transform 0.3s ease;
  }

  .free-bird:hover {
    transform: scale(1.05);
  }

  .action-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .registration-info {
      grid-template-columns: 1fr;
    }

    .action-card {
      padding: 2rem;
    }

    .step {
      gap: 1rem;
    }

    .step-number {
      width: 2rem;
      height: 2rem;
    }

    .free-bird {
      position: relative;
      top: auto;
      right: auto;
      width: 150px;
      margin: 2rem auto 0;
      display: block;
    }
  }
</style>