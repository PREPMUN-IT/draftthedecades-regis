---
import { Image } from "astro:assets";
import heroBg from "/public/CoverTitleBGV2.png";
---

<section class="hero">
  <div class="hero-background">
    <Image src={heroBg} alt="" class="hero-bg-image" />
  </div>

  <div class="container">
    <div class="hero-title font-display">WORLDS WE GOVERN</div>
    <div class="subtitle-container font-display">
      <div class="hero-subtitle">29/08/2026</div>
      <div class="hero-subtitle">30/08/2026</div>
    </div>
  </div>
  <div class="scroll-indicator">
    <div class="scroll-arrow"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -1;
  }

  .hero-bg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: brightness(0.9);
  }

  .title-container {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(15px);
    border-radius: 1rem;
    padding: 2rem;
    margin-bottom: 3rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    position: relative;
    z-index: 20;
  }

  .subtitle-container{
    display: flex;
    gap: clamp(1rem, 4vw, 6rem);
    justify-content: center;
    align-items: center;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--white);
    text-align: center;
  }

  .hero-subtitle {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin: 0;
    color: var(--white);
  }

  .title-line {
    display: block;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
    z-index: 10;
  }

  .scroll-arrow {
    width: 24px;
    height: 24px;
    border-right: 2px solid var(--white);
    border-bottom: 2px solid var(--white);
    transform: rotate(45deg);
    opacity: 0.7;
  }

  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  @media (max-width: 768px) {
    .title-container {
      padding: 1.5rem;
    }

    .hero-details {
      flex-direction: column;
      gap: 1rem;
    }

    .detail-item {
      padding: 0.75rem 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      text-align: center;
    }
  }
</style>
