---
import { Image } from 'astro:assets';
import heroBg from '/public/Cover Title BG.jpg';
---

<section class="hero">
  <div class="hero-background">
    <Image src={heroBg} alt="" class="hero-bg-image" />
  </div>
  
  <div class="container">
    <div class="hero-content">
      <div class="hero-text">
        <div class="title-container">
          <h1 class="hero-title font-display">
            <span class="title-line">Drafting the</span>
            <span class="title-line gold-gradient">Decades</span>
          </h1>
          
          <p class="hero-subtitle">
            An immersive SG60 policy simulation where participants tackle real historical dilemmas 
            and future challenges across Singapore's six decades of independence.
          </p>
        </div>
        
        <div class="hero-details">
          <div class="detail-item">
            <div class="detail-icon">📅</div>
            <div>
              <div class="detail-title">Event Dates</div>
              <div class="detail-text">16th-17th August 2025</div>
            </div>
          </div>
          
          <div class="detail-item">
            <div class="detail-icon">🏛️</div>
            <div>
              <div class="detail-title">Partnership</div>
              <div class="detail-text">Presented by PREPMUN and Moulmein-Cairnhill Youth Network, in collaboration with the People's Association and the National Youth Council.</div>
            </div>
          </div>
        </div>
        
        <div class="hero-actions">
          <a href="https://forms.gle/ARhbN4R2oymJavrM8" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-large">
            Register Now
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="#about" class="btn btn-secondary">Learn More</a>
        </div>
      </div>
    </div>
  </div>
  
  <div class="scroll-indicator">
    <div class="scroll-arrow"></div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .hero-background {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: -2;
  }

  .hero-bg-image {
    width: 100vw;
    height: 100vh;
    object-fit: cover;
    object-position: center;
  }

  .hero-content {
    padding-top: 6rem;
    padding-bottom: 4rem;
    position: relative;
    z-index: 10;
  }

  .hero-text {
    max-width: 700px;
    color: var(--white);
  }

  .title-container {
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(15px);
    border-radius: 1rem;
    padding: 2rem;
    margin-bottom: 3rem;
    border: 1px solid rgba(255, 255, 255, 0.2);
    position: relative;
    z-index: 20;
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 1.5rem;
  }

  .title-line {
    display: block;
  }

  .hero-subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    margin: 0;
    opacity: 0.95;
  }

  .hero-details {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
    flex-wrap: wrap;
  }

  .detail-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.15);
    padding: 1rem 1.5rem;
    border-radius: 0.75rem;
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.3);
  }

  .detail-icon {
    font-size: 1.5rem;
  }

  .detail-title {
    font-weight: 600;
    font-size: 0.875rem;
    opacity: 0.9;
  }

  .detail-text {
    font-weight: 500;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-large {
    padding: 1rem 2.5rem;
    font-size: 1.125rem;
    gap: 0.5rem;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    animation: bounce 2s infinite;
    z-index: 10;
  }

  .scroll-arrow {
    width: 24px;
    height: 24px;
    border-right: 2px solid var(--white);
    border-bottom: 2px solid var(--white);
    transform: rotate(45deg);
    opacity: 0.7;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% {
      transform: translateX(-50%) translateY(0);
    }
    40% {
      transform: translateX(-50%) translateY(-10px);
    }
    60% {
      transform: translateX(-50%) translateY(-5px);
    }
  }

  @media (max-width: 768px) {
    .title-container {
      padding: 1.5rem;
    }

    .hero-details {
      flex-direction: column;
      gap: 1rem;
    }

    .detail-item {
      padding: 0.75rem 1rem;
    }

    .hero-actions {
      flex-direction: column;
    }

    .btn {
      text-align: center;
    }
  }
</style>