---
import { Image } from "astro:assets";
import prepmunLogo from "/public/prep clear logo.png";
import majuLogo from "/public/maju.png";
import campusImpactLogo from "/public/campus_impact.png";
---

<section id="partners" class="partners section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title font-display">Our Partners</h2>
    </div>

    <div class="partners-content">
      <div class="partners-description">
        <p class="description-text">
          Drafting the Decades is a collaborative initiative by PREPMUN and the
          Moulmein-Cairnhill Youth Network, organised in commemoration of SG60.
          The event is proudly supported by the People's Association and the
          National Youth Council, whose continued commitment to youth
          development and civic engagement has made this ground-up initiative
          possible. Their support empowers youth to reflect on our nation's past
          policy choices and co-create visions for the future through meaningful
          dialogue and policy innovation.
        </p>
      </div>

      <div class="partners-logos">
        <div class="logo-tier">
          <h3 class="tier-title">Organised by:</h3>
          <div class="logo-row">
            <div class="logo-item">
              <Image src={prepmunLogo} alt="PREPMUN" class="partner-logo" />
            </div>
          </div>
        </div>

        <div class="logo-tier">
          <h3 class="tier-title">Supported by:</h3>
          <div class="logo-row">
            <div class="logo-item">
              <Image
                src={majuLogo}
                alt="Maju"
                class="partner-logo"
              />
            </div>
            <div class="logo-item">
              <Image
                src={campusImpactLogo}
                alt="National Youth Council"
                class="partner-logo"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .partners {
    background: transparent;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .partners-content {
    max-width: 900px;
    margin: 0 auto;
  }

  .partners-description {
    text-align: center;
    margin-bottom: 4rem;
  }

  .description-text {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--white);
    max-width: 800px;
    margin: 0 auto;
  }

  .partners-logos {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .logo-tier {
    text-align: center;
  }

  .tier-title {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    font-family: "Inter", sans-serif;
  }

  .logo-row {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .logo-row.single-logo {
    gap: 0;
  }

  .logo-item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .partner-logo {
    height: 150px;
    width: auto;
    object-fit: contain;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    border-radius: 12px;
  }

  .partner-logo:hover {
    transform: scale(1.05);
    opacity: 0.8;
  }

  .sg60-logo {
    height: 180px;
  }

  @media (max-width: 768px) {
    .section-title {
      font-size: 2rem;
    }

    .description-text {
      font-size: 1rem;
      padding: 0 1rem;
    }

    .partners-logos {
      gap: 2.5rem;
    }

    .logo-row {
      gap: 2rem;
      flex-direction: column;
    }

    .logo-row.single-logo {
      flex-direction: row;
    }

    .partner-logo {
      height: 120px;
    }

    .sg60-logo {
      height: 150px;
    }

    .tier-title {
      font-size: 1.125rem;
    }
  }

  @media (max-width: 480px) {
    .partners-description {
      margin-bottom: 3rem;
    }

    .logo-row {
      gap: 1.5rem;
    }

    .partner-logo {
      height: 105px;
    }

    .sg60-logo {
      height: 135px;
    }
  }
</style>
