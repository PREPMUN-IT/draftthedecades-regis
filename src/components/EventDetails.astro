---

---

<section id="event-details" class="event-details section-padding">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title font-display">WWG 2026</h2>
      <p class="section-subtitle">
        Join us at Worlds We Govern 2026 as we come together to explore the
        conflicts, compromises, and convictions that shape our society.
      </p>
    </div>

    <div class="details-grid">
      <div class="schedule-card card">
        <div class="card-header">
          <div class="card-icon">📅</div>
          <h3 class="card-title font-display">Dates:</h3>
        </div>

        <div class="schedule-content">
          <div class="day-schedule">
            <div class="day-header">
              <h4 class="day-title">Saturday, 29th August</h4>
            </div>
            <div class="time-slot">
              <span class="time">9:00 AM - 7:00 PM</span>
            </div>
          </div>

          <div class="day-schedule">
            <div class="day-header">
              <h4 class="day-title">Sunday, 30th August</h4>
            </div>
            <div class="time-slot">
              <span class="time">9:00 AM - 7:00 PM</span>
            </div>
          </div>
        </div>
      </div>

      <div class="location-card card">
        <div class="card-header">
          <div class="card-icon">📍</div>
          <h3 class="card-title font-display">Location:</h3>
        </div>

        <div class="location-content">
          <p class="location-text">Hwa Chong International</p>
        </div>

        <div class="divider"></div>

        <div class="card-header">
          <div class="card-icon">🎩</div>
          <h3 class="card-title font-display">Dress Code:</h3>
        </div>

        <div class="dress-code-content">
          <p class="dress-code-text">Western Business</p>
        </div>
      </div>
    </div>

    <div class="eligibility-card card">
      <div class="card-header">
        <div class="card-icon">👥</div>
        <h3 class="card-title font-display">Who Can Participate</h3>
      </div>

      <div class="eligibility-content">
        <p class="eligibility-text">
          We welcome all youth aged between 13 and 25 (inclusive) as of 30
          August 2026 who are:
        </p>
        <ul class="eligibility-list">
          <li>
            Currently enrolled in Singapore secondary, pre-tertiary or tertiary
            institutions
          </li>
          <li>Recent graduates transitioning between institutions</li>
          <li>Full-time National Servicemen (NSFs)</li>
        </ul>
      </div>
    </div>
  </div>

  <div class="mechanics-section">
    <div class="container">
      <h3 class="mechanics-title font-display">How It Works</h3>

      <div class="mechanics-content">
        <p>
          Worlds We Govern will immerse participants in the legislative process
          of the Singapore Parliament. With our various academic committees and
          unique mechanics, this journey will bring youths through spirited
          debates across several Readings, much akin to Singapore's real-world
          parliamentary procedure.
        </p>
        <p>
          While exploring the multifaceted and deep-rooted complexities in our
          society, participants can also seize this chance to put their ideas to
          the test with APEX, our custom-tuned AI engine, as it evaluates their
          policies in real-time, transforming them into confident and competent
          policymakers.
        </p>
        <p>
          Check out our <a href="your-link-here.pdf" class="prospectus-link"
            >Prospectus</a
          > for more details
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .event-details {
    background: transparent;
  }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    color: var(--white);
    max-width: 600px;
    margin: 0 auto;
  }

  .details-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .card-icon {
    font-size: 2rem;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-title {
    font-size: clamp(1.5rem, 2vw, 1.75rem);
    font-weight: 600;
    color: var(--white);
  }

  .day-schedule {
    margin-bottom: 2rem;
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.75rem;
    color: white;
  }

  .day-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .day-title {
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    font-weight: 600;
  }

  .day-format {
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.875rem;
    font-weight: 500;
  }

  .virtual {
    background: rgba(59, 130, 246, 0.1);
    color: var(--royal-blue);
  }

  .physical {
    background: rgba(245, 158, 11, 0.1);
    color: var(--gold);
  }

  .time-slot {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .time {
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    font-weight: 600;
    color: var(--primary-blue);
  }

  .description {
    color: var(--gray-600);
  }

  .venue-info {
    margin-top: 1rem;
    padding: 1rem;
    background: var(--white);
    border-radius: 0.5rem;
    color: var(--gray-700);
  }

  .eligibility-text {
    font-size: clamp(1rem, 1.1vw, 1.125rem);
    margin-bottom: 1rem;
    color: var(--white);
  }

  .eligibility-list {
    list-style: none;
  }

  .eligibility-list li {
    font-size: clamp(0.95rem, 1vw, 1.125rem);
    padding: 0.5rem 0;
    padding-left: 1.5rem;
    position: relative;
    color: var(--white);
  }

  .eligibility-list li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--gold);
    font-weight: bold;
  }
  .mechanics-section {
    margin-top: 5rem;
  }

  .mechanics-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 600;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--white);
  }

  .mechanics-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .mechanics-content p {
    font-size: clamp(1rem, 3vw, 1.5rem);
    color: var(--white);
    line-height: 1.6;
    padding-bottom: 2rem;
  }

  .prospectus-link {
    font-weight: bold;
    text-decoration: underline;
    color: inherit;
  }

  .location-content,
  .dress-code-content {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    padding: 1.5rem;
    margin-bottom: 1.5rem;
    text-align: center;
    border: 2px solid rgba(255, 255, 255, 0.2);
    border-radius: 0.75rem;
  }

  .location-text,
  .dress-code-text {
    font-size: clamp(1.25rem, 1.5vw, 1.5rem);
    font-weight: 600;
    color: white;
    margin: 0;
  }

  .divider {
    height: 3px;
    background-color: white;
    margin: 1.5rem 0;
  }

  @media (max-width: 768px) {
    .details-grid {
      grid-template-columns: 1fr;
    }

    .day-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .time-slot {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .mechanics-content p {
       font-size: clamp(1rem, 3vw, 1.5rem);
    }
  }
</style>
