---
import { Image } from 'astro:assets';
import decorationImage from '/public/IMG_0450.PNG';
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-main">
        <div class="footer-brand">
          <h3 class="brand-title font-display">Worlds We Govern</h3>
          <p class="brand-description">
            Exploring the conflicts, compromises, and convictions that shape our societies. 
            From policy drafting to historical inquiry, we invite youth to engage with 
            the past to better understand how to lead the future.
          </p>
        </div>
        
        <div class="footer-links">
          <div class="link-group">
            <h4 class="link-title">Event</h4>
            <ul class="link-list">
              <li><a href="#about" class="footer-link">About</a></li>
              <li><a href="#event-details" class="footer-link">Event Details</a></li>
              <li><a href="#registration" class="footer-link">Registration</a></li>
              <li><a href="#faq" class="footer-link">FAQ</a></li>
            </ul>
          </div>
          
          <div class="link-group">
            <h4 class="link-title">Contact</h4>
            <ul class="link-list">
              <li><span class="contact-item">Email: [XXX]</span></li>
              <li><span class="contact-item">Event Dates: 16-17 Aug 2025</span></li>
            </ul>
          </div>
        </div>
      </div>
      
      <div class="footer-bottom">
        <div class="footer-divider"></div>
        <div class="footer-meta">
          <p class="copyright">
            © 2025 Worlds We Govern. All rights reserved.
          </p>
          <div class="partnership">
            <span class="partnership-text">Supported by:</span>
            <span class="partner-name">People's Association</span>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="footer-decoration">
    <Image src={decorationImage} alt="" class="decoration-image" />
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, var(--primary-blue) 0%, var(--deep-blue) 100%);
    color: var(--white);
    position: relative;
    overflow: hidden;
  }

  .footer-content {
    padding: 4rem 0 2rem;
    position: relative;
    z-index: 2;
  }

  .footer-main {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 4rem;
    margin-bottom: 3rem;
  }

  .footer-brand {
    max-width: 500px;
  }

  .brand-title {
    font-size: 2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--white);
  }

  .brand-description {
    font-size: 1.125rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  .footer-links {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .link-title {
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--light-gold);
  }

  .link-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.8);
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .footer-link:hover {
    color: var(--light-gold);
  }

  .contact-item {
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.9rem;
  }

  .footer-divider {
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
    margin-bottom: 2rem;
  }

  .footer-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .copyright {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .partnership {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .partnership-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
  }

  .partner-name {
    color: var(--light-gold);
    font-weight: 600;
  }

  .footer-decoration {
    position: absolute;
    top: 0;
    right: 0;
    width: 500px;
    height: 100%;
    opacity: 0.15;
    z-index: 1;
    overflow: hidden;
  }

  .decoration-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  @media (max-width: 768px) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .footer-links {
      grid-template-columns: 1fr;
    }

    .footer-meta {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }

    .footer-decoration {
      width: 300px;
    }
  }
</style>